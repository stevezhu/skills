{
  "name": "@stzhu/skills",
  "version": "0.1.2",
  "description": "Skills CLI",
  "keywords": [
    "skills"
  ],
  "license": "MIT",
  "author": "Steve Zhu <4130171+stevezhu@users.noreply.github.com>",
  "repository": "github:stevezhu/skills",
  "bin": {
    "stz-skills": "dist/cli.mjs"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "imports": {
    "#*": "./src/*"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "node src/bin/cli.ts",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "lint": "pnpm run format:check && oxlint --type-aware",
    "lint:fix": "oxlint --type-aware --fix",
    "prepublishOnly": "pnpm run build",
    "pretest": "tsc --noEmit",
    "test": "vitest"
  },
  "dependencies": {
    "@stricli/auto-complete": "^1.2.6",
    "@stricli/core": "^1.2.6",
    "consola": "^3.4.2",
    "find-workspaces": "^0.3.1",
    "gray-matter": "^4.0.3",
    "terminal-link": "^5.0.0",
    "typebox": "^1.1.6",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@stzhu/tsconfig": "^0.3.0",
    "@types/node": "^25.4.0",
    "oxfmt": "^0.37.0",
    "oxlint": "^1.52.0",
    "oxlint-tsgolint": "^0.16.0",
    "tsdown": "^0.21.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=25"
  },
  "packageManager": "pnpm@10.30.3"
}
