{
  "name": "@stzhu/skills",
  "version": "0.1.0",
  "description": "Skills CLI",
  "keywords": [
    "skills"
  ],
  "license": "MIT",
  "author": "Steve Zhu <4130171+stevezhu@users.noreply.github.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/stevezhu/eslint-config.git"
  },
  "bin": {
    "__stz-skills_bash_complete": "dist/bash-complete.mjs",
    "stz-skills": "dist/cli.mjs"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "imports": {
    "#*": "./src/*"
  },
  "scripts": {
    "ai:claude": "claude",
    "ai:gemini": "SEATBELT_PROFILE=custom gemini",
    "build": "tsdown",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "lint": "oxlint --type-aware",
    "lint:fix": "oxlint --type-aware --fix",
    "postinstall": "stz-skills install",
    "prepublishOnly": "pnpm run build",
    "test": "vitest"
  },
  "dependencies": {
    "@stricli/auto-complete": "^1.2.6",
    "@stricli/core": "^1.2.6",
    "find-workspaces": "^0.3.1",
    "gray-matter": "^4.0.3",
    "typebox": "^1.1.5",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@stzhu/tsconfig": "^0.1.1",
    "@types/node": "^25.3.3",
    "oxfmt": "^0.36.0",
    "oxlint": "^1.51.0",
    "oxlint-tsgolint": "^0.16.0",
    "tsdown": "^0.20.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=25"
  },
  "packageManager": "pnpm@10.30.3"
}
