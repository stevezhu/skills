{
  "name": "@stzhu/skills",
  "version": "0.3.0",
  "description": "Skills CLI",
  "keywords": [
    "skills"
  ],
  "license": "MIT",
  "author": "Steve Zhu <4130171+stevezhu@users.noreply.github.com>",
  "repository": "github:stevezhu/skills",
  "bin": {
    "stz-skills": "dist/cli.mjs"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "build": "tsdown",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "lint": "pnpm run format:check && oxlint --type-aware",
    "lint:fix": "oxlint --type-aware --fix",
    "prepublishOnly": "pnpm run build",
    "pretest": "tsc --noEmit",
    "test": "vitest",
    "test:coverage": "vitest --coverage"
  },
  "dependencies": {
    "@stricli/auto-complete": "^1.2.6",
    "@stricli/core": "^1.2.6",
    "find-workspaces": "^0.3.1",
    "gray-matter": "^4.0.3",
    "typebox": "^1.1.14",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@stzhu/tsconfig": "^0.4.0",
    "@types/node": "^25.5.2",
    "@vitest/coverage-v8": "4.1.2",
    "oxfmt": "^0.43.0",
    "oxlint": "^1.58.0",
    "oxlint-tsgolint": "^0.19.0",
    "tsdown": "^0.21.7",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  },
  "engines": {
    "node": ">=25"
  },
  "packageManager": "pnpm@10.33.0"
}
