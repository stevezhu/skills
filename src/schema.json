{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["date", "type", "status", "agent", "branch", "models"],
  "properties": {
    "date": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$"
    },
    "type": {
      "type": "string",
      "enum": ["activity", "research", "decision", "plan"]
    },
    "status": {
      "type": "string",
      "enum": [
        "complete",
        "in-progress",
        "abandoned",
        "success",
        "failure",
        "partial"
      ]
    },
    "agent": { "type": "string", "minLength": 1 },
    "branch": { "type": "string", "minLength": 1 },
    "models": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    },
    "session_id": { "type": "string" },
    "task_id": { "type": "string" },
    "cost": { "type": "string" },
    "tags": { "type": "array", "items": { "type": "string" } },
    "files_modified": { "type": "array", "items": { "type": "string" } },
    "related_plan": { "type": "string" }
  }
}
